<     // Remove cookie/consent/gdpr elements
<     const selectors = [
<       '[class*="cookie"]', '[class*="Cookie"]',
<       '[class*="consent"]', '[class*="Consent"]',
<       '[class*="gdpr"]', '[class*="GDPR"]',
<       '[id*="cookie"]', '[id*="Cookie"]',
<       '[id*="consent"]', '[id*="Consent"]',
<       '[id*="onetrust"]', '[class*="onetrust"]',
<       '[id*="CybotCookiebot"]',
<       '[class*="cc-banner"]', '[class*="cc-window"]',
<       '[aria-label*="cookie" i]', '[aria-label*="consent" i]',
<     ];
<     document.querySelectorAll(selectors.join(',')).forEach(el => {
<       try { el.remove(); } catch(e) {}
<     });
< 
<     // v15: Remove modal/popup/dialog overlays — ONLY if covering >50% viewport with high z-index
<     // Conservative: only remove clearly disruptive overlays, not regular UI elements
<     const popupSel = '[role="dialog"],[role="alertdialog"]';
<     document.querySelectorAll(popupSel).forEach(el => {
<       try {
<         const s = getComputedStyle(el);
<         const isFixed = s.position === 'fixed' || s.position === 'absolute';
<         if (isFixed && el.offsetWidth >= window.innerWidth * 0.4 && el.offsetHeight >= window.innerHeight * 0.3) {
<           const isNav = el.matches('header, nav, [role="navigation"]') || el.querySelector('nav, [role="navigation"]');
<           if (!isNav) el.remove();
<         }
<       } catch(e) {}
<     });
< 
<     // Remove high z-index fixed/sticky overlays (but keep navbars/headers)
<     document.querySelectorAll('*').forEach(el => {
<       try {
<         const s = getComputedStyle(el);
<         const z = parseInt(s.zIndex);
<         const isFixed = s.position === 'fixed' || s.position === 'sticky';
<         if (isFixed && z > 999 && el.offsetHeight > 50) {
<           const isNav = el.matches('header, nav, [role="navigation"]') || el.querySelector('nav, [role="navigation"]');
<           const tag = el.tagName.toLowerCase();
<           if (!isNav && tag !== 'header' && tag !== 'nav') {
<             el.remove();
<           }
<         }
<       } catch(e) {}
<     });
< 
<     // v17: Remove full-screen fixed/absolute overlays covering >70% viewport
<     // Only removes elements that have a close button inside (strong signal it's a popup)
<     document.querySelectorAll('*').forEach(el => {
<       try {
<         const s = getComputedStyle(el);
<         if (s.position !== 'fixed' && s.position !== 'absolute') return;
<         const z = parseInt(s.zIndex) || 0;
<         if (z < 10) return;
<         const w = el.offsetWidth, h = el.offsetHeight;
<         const vw = window.innerWidth, vh = window.innerHeight;
<         if (w >= vw * 0.7 && h >= vh * 0.5) {
<           const isNav = el.matches('header, nav, [role="navigation"], main, section') || el.querySelector('nav, [role="navigation"]');
<           if (!isNav && el.querySelector('[class*="close"],[class*="Close"],[aria-label*="close" i],button[class*="dismiss"]')) {
<             el.remove();
<           }
<         }
<       } catch(e) {}
<     });
